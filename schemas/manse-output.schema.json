{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sinjeomunni.app/schemas/manse-output-v0.7.schema.json",
  "title": "Korean Manse Calculator 만세력 계산 출력 스키마 v0.7",
  "description": "사주 에이전트가 받는 만세력 계산 전용 JSON. 스킬은 계산만 하고 해석은 본체가 담당한다.",
  "type": "object",
  "required": [
    "status",
    "version",
    "profile"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "unsupported_calendar",
        "missing_solar_terms_cache",
        "error"
      ]
    },
    "version": {
      "type": "string",
      "const": "0.7.0"
    },
    "profile": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "seoul_corrected_manse_v0.7"
        },
        "version": {
          "type": "string",
          "const": "0.7.0"
        },
        "purpose": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "properties": {
        "calendar": {
          "type": "string",
          "const": "solar"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "time": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "birthplace": {
          "type": "object",
          "description": "사용자에게 출생지를 받지 않고 서울을 기본 가정으로 사용한다.",
          "properties": {
            "input_collected": {
              "type": "boolean",
              "const": false
            },
            "default_used": {
              "$ref": "#/$defs/birthplace"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "policies": {
      "type": "object",
      "properties": {
        "country_scope": {
          "const": "KR_only"
        },
        "birthplace_input": {
          "type": "boolean",
          "const": false
        },
        "default_birthplace": {
          "$ref": "#/$defs/birthplace"
        },
        "longitude_correction": {
          "type": "string"
        },
        "apparent_solar_time": {
          "type": "boolean",
          "const": false
        },
        "true_solar_time": {
          "type": "boolean",
          "const": false
        },
        "overseas_birth": {
          "type": "boolean",
          "const": false
        },
        "lunar_calendar": {
          "type": "string"
        },
        "dst": {
          "type": "string"
        },
        "year_boundary": {
          "type": "string"
        },
        "month_boundary": {
          "type": "string"
        },
        "day_pillar_policy": {
          "type": "string"
        },
        "day_boundary": {
          "type": "string"
        },
        "zi_hour": {
          "type": "string",
          "const": "23:00-00:59"
        },
        "llm_calculation": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "normalized_time": {
      "type": "object",
      "description": "대한민국 법정시/서머타임 보정 후 서울 -32분 보정 결과. 시간 미상일 때는 basis_time_kst=null.",
      "properties": {
        "legal_local_time": {
          "type": "string"
        },
        "standard_time_kst_before_longitude_correction": {
          "type": "string"
        },
        "basis_time_kst": {
          "type": [
            "string",
            "null"
          ]
        },
        "calculation_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "basis_date": {
          "type": "string"
        },
        "offset_minutes_at_birth": {
          "type": [
            "integer",
            "null"
          ]
        },
        "basis_adjustment_minutes": {
          "type": [
            "integer",
            "null"
          ]
        },
        "total_adjustment_minutes": {
          "type": [
            "integer",
            "null"
          ]
        },
        "dst_applied": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "timezone_source": {
          "type": "string"
        },
        "longitude_correction": {
          "type": "object",
          "additionalProperties": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "calendar_data": {
      "type": "object",
      "required": [
        "solar_date_for_day_pillar",
        "day_pillar_policy"
      ],
      "properties": {
        "solar_date_for_day_pillar": {
          "type": "string",
          "format": "date"
        },
        "time_corrected_date_for_year_month_and_hour": {
          "type": "string",
          "format": "date"
        },
        "day_pillar_policy": {
          "type": "string"
        },
        "day_ganzhi_source": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "solar_terms": {
      "type": "object",
      "properties": {
        "sources_by_year": {
          "type": "object",
          "additionalProperties": true
        },
        "year_boundary_ipchun": {
          "type": "object",
          "additionalProperties": true
        },
        "month_boundary": {
          "type": "object",
          "additionalProperties": true
        },
        "next_month_boundary": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "pillars": {
      "type": "object",
      "required": [
        "year",
        "month",
        "day",
        "hour"
      ],
      "properties": {
        "year": {
          "$ref": "#/$defs/pillar"
        },
        "month": {
          "$ref": "#/$defs/pillar"
        },
        "day": {
          "$ref": "#/$defs/pillar"
        },
        "hour": {
          "anyOf": [
            {
              "$ref": "#/$defs/pillar"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "summary": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "next_action": {
      "type": "string"
    }
  },
  "$defs": {
    "birthplace": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "서울특별시"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "standard_meridian": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "pillar": {
      "type": "object",
      "required": [
        "ganzhi",
        "ko",
        "stem",
        "branch",
        "basis"
      ],
      "properties": {
        "ganzhi": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "ko": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        },
        "stem": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "basis": {
          "type": "string"
        },
        "ambiguous": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "warning": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "notice",
            "near_jeolgi_boundary",
            "near_ipchun_boundary",
            "summer_time_period",
            "standard_time_change_period",
            "hour_unknown",
            "data_review_note",
            "lunar_input_received",
            "overseas_input_received",
            "data_quality_review",
            "year_out_of_range"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}